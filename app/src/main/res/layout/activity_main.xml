<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ui.nasabah.MainActivity">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CardView for the Logo and its text to give it a nice shadow as seen in the image -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_logo"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:src="@drawable/recycle_logo"
                    android:contentDescription="@string/recycle_logo" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/text_bank_sampah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bank_sampah"
            android:textColor="#064214"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/text_winduherang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/winduherang"
            android:textColor="#064214"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="-4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>